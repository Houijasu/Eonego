<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>

    <!-- Compiler optimizations -->
    <Optimize>true</Optimize>
    <DebugType>none</DebugType>
    <Tailcalls>true</Tailcalls>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>

    <!-- Allow unsafe code for pointer/bitboard optimizations -->
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>

    <!-- GC tuned for throughput. A/B'd workstation+non-concurrent (2026-06-29): no gain on the 0-alloc search
         (~2.01M vs ~2.04M nps 8T), so Server+Concurrent retained (conventional + marginally faster). -->
    <ServerGarbageCollection>true</ServerGarbageCollection>
    <ConcurrentGarbageCollection>true</ConcurrentGarbageCollection>
    <RetainVMGarbageCollection>true</RetainVMGarbageCollection>

    <!-- Runtime / JIT tuning -->
    <TieredCompilation>false</TieredCompilation>
    <ReadyToRun>true</ReadyToRun>
    <UseWindowsThreadPool>true</UseWindowsThreadPool>

    <!-- Native AOT publishing -->
    <PublishAot>true</PublishAot>
    <InvariantGlobalization>true</InvariantGlobalization>
    <!-- OptimizationPreference (NOT IlcOptimizationPreference, which the ILCompiler targets ignore)
         drives the optimize-for-speed codegen flag and auto-enables IlcPgoOptimize (framework MIBC PGO)
         plus VxSort. Verified vs microsoft.dotnet.ilcompiler 10.0.5 Native.targets (lines 29/165/274). -->
    <OptimizationPreference>Speed</OptimizationPreference>
    <!-- Use the build machine's full ISA (AVX2 + BMI1/BMI2/PEXT + POPCNT/LZCNT) so the AOT binary uses
         the PEXT slider backend instead of the magic fallback. `native` targets THIS CPU (13980HX) — the
         binary then requires a CPU with at least these features to run. -->
    <IlcInstructionSet>native</IlcInstructionSet>
    <StackTraceSupport>false</StackTraceSupport>
    <UseSystemResourceKeys>true</UseSystemResourceKeys>
    <MetadataUpdaterSupport>false</MetadataUpdaterSupport>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Bitboard.fs" />
    <Compile Include="Move.fs" />
    <Compile Include="Zobrist.fs" />
    <Compile Include="Accumulator.fs" />
    <Compile Include="AccumulatorCache.fs" />
    <Compile Include="Position.fs" />
    <Compile Include="Threats.fs" />
    <Compile Include="NNUE.fs" />
    <Compile Include="MoveGeneration.fs" />
    <Compile Include="History.fs" />
    <Compile Include="MovePick.fs" />
    <Compile Include="Transposition.fs" />
    <Compile Include="DAGNode.fs" />
    <Compile Include="DAGQueue.fs" />
    <Compile Include="Search.fs" />
    <Compile Include="Tooling.fs" />
    <Compile Include="UCI.fs" />
    <Compile Include="Program.fs" />
  </ItemGroup>

  <!-- Embed the NNUE evaluator into the binary so the exe is self-contained. Conditional on the net
       existing: nets/ is gitignored (the net is large/licensed), so a fresh checkout (CI, a new contributor)
       builds without it — the exe then has no embedded net and tests that need one soft-skip. Local/release
       builds embed it as before. -->
  <ItemGroup Condition="Exists('..\nets\nn-f8a759c05f9f.nnue')">
    <EmbeddedResource Include="..\nets\nn-f8a759c05f9f.nnue" LogicalName="eval.nnue" />
  </ItemGroup>

</Project>
